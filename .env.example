# Database
# For Railway PostgreSQL, paste your connection string here
DATABASE_URL=postgresql://user:password@host:5432/fscare_db
# For local dev with SQLite (no setup needed):
# DATABASE_URL=sqlite:///./fscare.db

# Email (Gmail example — use an App Password, not your regular Gmail password)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password

# FS Care admin email — all new request notifications go here
FSCARE_EMAIL=info@fscare.ng
